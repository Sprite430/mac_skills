# ============================================
# 国库集中支付系统 - Oracle 数据库连接配置
# ============================================
# 配置说明:
# 1. 将此文件复制为 connect.local.env
# 2. 修改 connect.local.env 中的实际连接信息
# 3. 运行脚本时会自动加载 connect.local.env

# ------------------------------
# 数据库连接参数
# ------------------------------
# 数据库服务器地址
DB_HOST="172.16.101.111"

# Oracle 监听端口 (通常为 1521)
DB_PORT="1521"

# Oracle 服务名
DB_SERVICE="orcl"

# 数据库用户名
DB_USER="SICHUAN_LESHAN"

# 数据库密码
DB_PASS="1"

# ------------------------------
# 默认业务参数
# ------------------------------
# 行政区划代码
REGION_CODE="511100"

# 银行ID
BANK_ID="1672"

# 账户类型代码 - 11: 零余额账户, 5: 清算账户
ACCOUNT_TYPE="11"

# ------------------------------
# Docker 容器配置
# ------------------------------
# Oracle 容器名称
ORACLE_CONTAINER="oracle-21c-local"

# ------------------------------
# 使用方法
# ------------------------------
# 1. 复制配置文件
#    cp connect.env connect.local.env
#
# 2. 修改 connect.local.env 中的实际参数
#    vi connect.local.env
#
# 3. 加载配置
#    source connect.local.env
#
# 4. 执行查询
#    docker exec $ORACLE_CONTAINER bash -c "echo \"SELECT * FROM DUAL;\" | sqlplus -s $DB_USER/$DB_PASS@//$DB_HOST:$DB_PORT/$DB_SERVICE"